<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
{% if tag %}
<title>{{ tag }} · 快连下载</title>
<meta name="description" content="{{ tag }}相关的快连下载教程与客户端使用说明。">
{% else %}
<title>{% set docTitle = pageTitle or title %}{% if docTitle %}{{ docTitle }} | {% endif %}{{ site.brand }}</title>
<meta name="description" content="{{ pageDescription or description or site.description }}">
{% endif %}
<meta name="keywords" content="{{ pageKeywords or site.keywords }}">
<link rel="icon" href="/favicon.ico" sizes="any">
<link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32.png">
<link rel="apple-touch-icon" href="/images/apple-touch-icon.png">
<link rel="stylesheet" href="/css/style.css">
<script charset="UTF-8" id="LA_COLLECT" src="//sdk.51.la/js-sdk-pro.min.js"></script>
<script>LA.init({id:"{{ site.laId }}",ck:"{{ site.laId }}"})</script>
