<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="{{ site.brand }}首页">
      <img class="brand-logo" src="/images/logo.png" width="40" height="40" alt="快连官方 Logo" decoding="async">
      <span>{{ site.brand }}</span>
    </a>
    <nav class="site-nav" aria-label="主导航">
      <ul>
        {% for item in site.nav %}
        <li>
          <a href="{{ item.url }}"{% if navKey == item.key %} aria-current="page"{% endif %}>{{ item.label }}</a>
        </li>
        {% endfor %}
      </ul>
    </nav>
  </div>
</header>
