---
layout: layouts/base.njk
---
<div class="container breadcrumb">
  <a href="/">快连下载</a> / <a href="/blog/">教程</a> / <span>{{ title }}</span>
</div>

<article class="container section" style="padding-top:24px;">
  <div class="info-panel">
    <header>
      <h1>{{ title }}</h1>
      <p style="color:var(--muted);margin-top:12px;font-size:0.95rem;">
        {{ page.date | dateZh }}
        {% if category %} · <a href="/categories/{{ category | slug }}/">{{ category }}</a>{% endif %}
        {% if tags and tags.length %}
        ·
        {% for t in tags %}
        <a href="/tags/{{ t | slug }}/">{{ t }}</a>{% if not loop.last %} · {% endif %}
        {% endfor %}
        {% endif %}
      </p>
    </header>
    {% include "partials/video-lazy.njk" %}
    <div class="article-body" style="margin-top:24px;">
      {{ content | safe }}
    </div>
    {% set prevPost = collections.posts | getPreviousCollectionItem(page) %}
    {% set nextPost = collections.posts | getNextCollectionItem(page) %}
    <nav class="nav-prev-next" aria-label="文章导航">
      {% if prevPost %}
      <a href="{{ prevPost.url }}"><span class="label">上一篇</span>{{ prevPost.data.title }}</a>
      {% else %}<div></div>{% endif %}
      {% if nextPost %}
      <a href="{{ nextPost.url }}"><span class="label">下一篇</span>{{ nextPost.data.title }}</a>
      {% endif %}
    </nav>
  </div>
</article>

<section class="section">
  <div class="container">
    <h2>更多快连下载内容</h2>
    <div class="card-grid" style="margin-top:20px;">
      {% for item in collections.posts | slice(0, 6) %}
      {% if item.url != page.url %}
      <article class="card">
        <a href="{{ item.url }}" class="card-thumb">
          <img src="{{ (item.data.title + ' 快连下载') | bingImg }}" alt="{{ item.data.title }} 快连下载" loading="lazy" width="400" height="225">
        </a>
        <div class="card-body">
          <h3><a href="{{ item.url }}">{{ item.data.title }}</a></h3>
          <p>{{ item.data.description }}</p>
        </div>
      </article>
      {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
